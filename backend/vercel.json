{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["dist/**", "public/**", "node_modules/**", "prisma/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/dashboard(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ]
}
